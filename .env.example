# ── 접속 비밀번호 ────────────────────────────────────────────
# 설정하면 사이트 전체가 로그인 화면으로 보호됩니다.
# 로그인 화면에서 이 값을 입력하면 90일간 자동 로그인 유지됩니다.
# (비워두면 보호 없이 공개됩니다 — 로컬 개발용)
APP_PASSWORD=

# ── 데이터 저장소 (Vercel KV / Upstash Redis) ────────────────
# Vercel 대시보드에서 Upstash Redis(또는 KV)를 프로젝트에 연결하면
# 아래 값들이 자동으로 주입됩니다. 로컬에서 Redis를 쓰려면 직접 채우세요.
# 둘 다 비어 있으면 로컬 파일(data/data.json)에 저장합니다.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (Upstash 직접 연동 시 대체 이름 — 위 값이 없을 때 사용)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
